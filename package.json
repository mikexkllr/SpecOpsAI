{
  "name": "specops-ai",
  "version": "0.1.0",
  "description": "Spec-Driven Development desktop IDE with integrated AI agent",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "dev": "npm run build:main && concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.40",
    "@langchain/google-genai": "^2.1.27",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.4",
    "deepagents": "^1.9.0",
    "marked": "^18.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "overrides": {
    "p-retry": "^4.6.2",
    "p-queue": "^6.6.2"
  }
}
